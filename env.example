# ──────────────────────────────────────────────────────────────────────────────
# env.example — rename this file to .env before running the project.
# Never commit your real .env file (it is already in .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# ─── Anthropic (server-only — Phase 1) ───────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional — swap model without redeploying (default: claude-haiku-4-5)
ANTHROPIC_MODEL=claude-haiku-4-5

# ─── Supabase (server-side route handlers only — Phase 2) ────────────────────
# NEXT_PUBLIC_SUPABASE_URL is intentionally public-safe (just the project URL).
NEXT_PUBLIC_SUPABASE_URL=
# WARNING: The service-role key bypasses RLS.
# It is imported ONLY by lib/supabase.ts which uses `import 'server-only'`
# to prevent it from ever appearing in the client bundle.
SUPABASE_SERVICE_ROLE_KEY=
